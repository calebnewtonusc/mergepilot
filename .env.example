# MergePilot Environment Configuration
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub API token (for PR outcome discovery)
# Get from: https://github.com/settings/tokens
# Scopes needed: repo (read), public_repo
GITHUB_TOKEN=ghp_your_github_token_here

# Anthropic API (for synthesis reasoning and complex pair generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Synthesis (choose one or both) ────────────────────────────────────────────

# vLLM synthesis server URL (for Qwen2.5-72B local/Azure synthesis)
VLLM_SYNTHESIS_URL=http://localhost:8000/v1

# vLLM synthesis server auth (set any string, used to secure synthesis API)
VLLM_API_KEY=your_vllm_secret_key

# ── Optional (recommended) ────────────────────────────────────────────────────

# Weights & Biases (training monitoring and experiment tracking)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=mergepilot-training
WANDB_ENTITY=your_wandb_username

# HuggingFace (model upload post-training)
HF_TOKEN=hf_...
HF_REPO=calebnewtonusc/mergepilot-7b-v1

# ── Infrastructure ────────────────────────────────────────────────────────────

# Azure (for burst synthesis compute)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=mergepilot-synthesis
AZURE_REGION=eastus

# ── Training Config ───────────────────────────────────────────────────────────

# Base model (default: Qwen2.5-7B-Coder-Instruct)
BASE_MODEL=Qwen/Qwen2.5-7B-Coder-Instruct

# Training output directory
OUTPUT_DIR=./checkpoints

# Data directory (gitignored, store training data here)
DATA_DIR=./data

# Number of GPUs (default: 18 for full A6000 cluster)
NUM_GPUS=18

# ── Inference ─────────────────────────────────────────────────────────────────

# Port for MergePilot API server
API_PORT=8000

# GitHub App credentials (for production review agent)
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY_PATH=./keys/mergepilot-app.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret
