data/
checkpoints/
results/
*.jsonl
*.parquet
*.arrow
*.bin
*.safetensors

# ── Model Files ───────────────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.gguf

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
