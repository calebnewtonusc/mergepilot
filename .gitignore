.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ── WandB ─────────────────────────────────────────────────────────────────────
wandb/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
