.installed.cfg
*.egg
MANIFEST
*.pyc
*.pyo
*.pyd

# ── Virtual Environments ──────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
keys/
secrets/

